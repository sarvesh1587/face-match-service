# Face Match Service — Environment Variables
# Copy this file: cp .env.example .env
# Fill in your values. Never commit .env to git.

# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development         # development | staging | production
APP_VERSION=1.0.0
LOG_LEVEL=INFO
DEBUG=false

# ── Qdrant ─────────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost        # Use 'qdrant' when running via docker compose
QDRANT_PORT=6333
QDRANT_COLLECTION=face_embeddings
# QDRANT_API_KEY=            # Required for Qdrant Cloud; leave blank for local

# ── InsightFace ────────────────────────────────────────────────────────────────
INSIGHTFACE_MODEL=buffalo_l  # buffalo_l = ArcFace R100 (best quality)
                             # buffalo_s = lighter model for constrained envs
INSIGHTFACE_CTX_ID=-1        # -1 = CPU, 0 = first GPU

# ── Matching ───────────────────────────────────────────────────────────────────
# Derived from threshold calibration. See docs/THRESHOLD_ANALYSIS.md
MATCH_THRESHOLD=0.40
TOP_K=5

# ── Face Quality Gates ─────────────────────────────────────────────────────────
MIN_FACE_SIZE=60
MIN_DETECTION_SCORE=0.70
BLUR_LAPLACIAN_THRESHOLD=80.0
